#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR="/var/backups/mysql"
TIMESTAMP="$(date +%F_%H-%M-%S)"
BACKUP_FILE="${BACKUP_DIR}/{{ mysql_database }}_${TIMESTAMP}.sql.gz"

mkdir -p "${BACKUP_DIR}"

mysqldump --protocol=socket -uroot --single-transaction --quick --routines --triggers {{ mysql_database }} | gzip > "${BACKUP_FILE}"

find "${BACKUP_DIR}" -type f -name '*.sql.gz' -mtime +{{ backup_retention_days }} -delete
